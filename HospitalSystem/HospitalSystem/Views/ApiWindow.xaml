<Window x:Class="HospitalSystem.Views.ApiWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="API"
        Height="440" Width="620"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource CanvasBrush}">

    <Grid Margin="20">
        <Border Style="{StaticResource CardStyle}">
            <StackPanel>
                <TextBlock Text="Интеграция с API" FontSize="20" FontWeight="Bold" Margin="0,0,0,4"/>
                <TextBlock Text="Курс ЦБ РФ запрашивается через открытое API и логируется в таблицу ApiLogs"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,16"/>

                <Button x:Name="GetDataButton" Content="Получить курс валют" Style="{StaticResource PrimaryButtonStyle}" Click="GetData_Click"/>

                <TextBlock Text="Ответ" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,16,0,4"/>
                <TextBox x:Name="ResultBox"
                         Height="200"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         IsReadOnly="True"
                         VerticalContentAlignment="Top"
                         Padding="10,8"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
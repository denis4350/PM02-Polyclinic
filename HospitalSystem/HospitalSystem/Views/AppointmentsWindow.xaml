<Window x:Class="HospitalSystem.Views.AppointmentsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Записи на приём"
        Height="660" Width="1050"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource CanvasBrush}">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="330"/>
        </Grid.ColumnDefinitions>

        <Border Style="{StaticResource CardStyle}" Margin="0,0,10,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                    <RadioButton x:Name="FilterAll" Content="Все" GroupName="DateFilter" Style="{StaticResource FilterToggleStyle}" IsChecked="True" Checked="Filter_Changed"/>
                    <RadioButton x:Name="FilterToday" Content="Сегодня" GroupName="DateFilter" Style="{StaticResource FilterToggleStyle}" Checked="Filter_Changed"/>
                    <RadioButton x:Name="FilterUpcoming" Content="Предстоящие" GroupName="DateFilter" Style="{StaticResource FilterToggleStyle}" Checked="Filter_Changed"/>
                    <RadioButton x:Name="FilterPast" Content="Прошедшие" GroupName="DateFilter" Style="{StaticResource FilterToggleStyle}" Checked="Filter_Changed"/>
                </StackPanel>

                <Grid Grid.Row="1">
                    <DataGrid x:Name="AppointmentsGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionChanged="AppointmentsGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding AppointmentID}" Width="45"/>
                            <DataGridTextColumn Header="Пациент" Binding="{Binding PatientName}" Width="*"/>
                            <DataGridTextColumn Header="Врач" Binding="{Binding DoctorName}" Width="*"/>
                            <DataGridTextColumn Header="Дата" Binding="{Binding AppointmentDate, StringFormat=dd.MM.yyyy}" Width="90"/>
                            <DataGridTextColumn Header="Время" Binding="{Binding TimeDisplay}" Width="60"/>
                            <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="110"/>
                            <DataGridTextColumn Header="Комментарий" Binding="{Binding Comment}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock x:Name="NoResultsText"
                               Text="Нет записей за выбранный период"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="13"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Top"
                               Margin="0,40,0,0"
                               Visibility="Collapsed"/>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Column="1" Style="{StaticResource CardStyle}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Запись на приём" FontSize="18" FontWeight="Bold" Margin="0,0,0,14"/>

                    <TextBlock Text="Пациент" Style="{StaticResource FieldLabelStyle}"/>
                    <ComboBox x:Name="PatientBox" SelectedValuePath="Id" Margin="0,0,0,10">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Text="Врач" Style="{StaticResource FieldLabelStyle}"/>
                    <ComboBox x:Name="DoctorBox" SelectedValuePath="Id" Margin="0,0,0,10">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Text="Дата" Style="{StaticResource FieldLabelStyle}"/>
                    <DatePicker x:Name="DateBox" Margin="0,0,0,10"/>

                    <TextBlock Text="Время" Style="{StaticResource FieldLabelStyle}"/>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="HourBox" Grid.Column="0"/>
                        <TextBlock Grid.Column="1" Text=":" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <ComboBox x:Name="MinuteBox" Grid.Column="2"/>
                    </Grid>

                    <TextBlock Text="Статус" Style="{StaticResource FieldLabelStyle}"/>
                    <ComboBox x:Name="StatusBox" Margin="0,0,0,10"/>

                    <TextBlock Text="Комментарий" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox x:Name="CommentBox" Margin="0,0,0,10" Height="60" TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top" Padding="10,8"/>

                    <Button x:Name="SaveButton" Content="Добавить запись" Style="{StaticResource SuccessButtonStyle}" Margin="0,10,0,10" Click="Save_Click"/>
                    <Button Content="Новая запись" Style="{StaticResource InfoButtonStyle}" Margin="0,0,0,10" Click="NewAppointment_Click"/>
                    <Button Content="Удалить" Style="{StaticResource DangerButtonStyle}" Margin="0,0,0,10" Click="Delete_Click"/>
                    <Button Content="Обновить список" Style="{StaticResource InfoButtonStyle}" Click="Refresh_Click"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
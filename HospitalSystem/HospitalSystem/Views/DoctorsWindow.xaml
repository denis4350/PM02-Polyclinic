<Window x:Class="HospitalSystem.Views.DoctorsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Врачи"
        Height="620" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource CanvasBrush}">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <Border Style="{StaticResource CardStyle}" Margin="0,0,10,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock Text="Поиск" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox x:Name="SearchBox" TextChanged="SearchBox_TextChanged"/>
                </StackPanel>

                <Grid Grid.Row="1">
                    <DataGrid x:Name="DoctorsGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionChanged="DoctorsGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding DoctorID}" Width="45"/>
                            <DataGridTextColumn Header="Фамилия" Binding="{Binding LastName}" Width="*"/>
                            <DataGridTextColumn Header="Имя" Binding="{Binding FirstName}" Width="*"/>
                            <DataGridTextColumn Header="Отчество" Binding="{Binding MiddleName}" Width="*"/>
                            <DataGridTextColumn Header="Кабинет" Binding="{Binding Office}" Width="80"/>
                            <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock x:Name="NoResultsText"
                               Text="Ничего не найдено"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="13"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Top"
                               Margin="0,40,0,0"
                               Visibility="Collapsed"/>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Column="1" Style="{StaticResource CardStyle}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Врач" FontSize="18" FontWeight="Bold" Margin="0,0,0,14"/>

                    <TextBlock Text="Фамилия" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox x:Name="LastNameBox" Margin="0,0,0,10"/>

                    <TextBlock Text="Имя" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox x:Name="FirstNameBox" Margin="0,0,0,10"/>

                    <TextBlock Text="Отчество" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox x:Name="MiddleNameBox" Margin="0,0,0,10"/>

                    <TextBlock Text="Специальность" Style="{StaticResource FieldLabelStyle}"/>
                    <ComboBox x:Name="SpecialtyBox" SelectedValuePath="SpecialtyID" Margin="0,0,0,10">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding SpecialtyName}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Text="Кабинет" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox x:Name="OfficeBox" Margin="0,0,0,10"/>

                    <TextBlock Text="Телефон" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox x:Name="PhoneBox" Margin="0,0,0,10"/>

                    <Button x:Name="SaveButton" Content="Добавить врача" Style="{StaticResource SuccessButtonStyle}" Margin="0,10,0,10" Click="Save_Click"/>
                    <Button Content="Новая запись" Style="{StaticResource InfoButtonStyle}" Margin="0,0,0,10" Click="NewDoctor_Click"/>
                    <Button Content="Удалить" Style="{StaticResource DangerButtonStyle}" Margin="0,0,0,10" Click="Delete_Click"/>
                    <Button Content="Обновить список" Style="{StaticResource InfoButtonStyle}" Click="Refresh_Click"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
<Window x:Class="HospitalSystem.Views.PatientsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Пациенты"
        Height="640" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource CanvasBrush}">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <Border Style="{StaticResource CardStyle}" Margin="0,0,10,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock Text="Поиск" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox x:Name="SearchBox" TextChanged="SearchBox_TextChanged"/>
                </StackPanel>

                <Grid Grid.Row="1">
                    <DataGrid x:Name="PatientsGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionChanged="PatientsGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding PatientID}" Width="45"/>
                            <DataGridTextColumn Header="Фамилия" Binding="{Binding LastName}" Width="*"/>
                            <DataGridTextColumn Header="Имя" Binding="{Binding FirstName}" Width="*"/>
                            <DataGridTextColumn Header="Отчество" Binding="{Binding MiddleName}" Width="*"/>
                            <DataGridTextColumn Header="Дата рождения" Binding="{Binding BirthDate, StringFormat=dd.MM.yyyy}" Width="110"/>
                            <DataGridTextColumn Header="Пол" Binding="{Binding Gender}" Width="80"/>
                            <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="*"/>
                            <DataGridTextColumn Header="Полис" Binding="{Binding PolicyNumber}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock x:Name="NoResultsText"
                               Text="Ничего не найдено"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="13"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Top"
                               Margin="0,40,0,0"
                               Visibility="Collapsed"/>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Column="1" Style="{StaticResource CardStyle}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Пациент" FontSize="18" FontWeight="Bold" Margin="0,0,0,14"/>

                    <TextBlock Text="Фамилия" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox x:Name="LastNameBox" Margin="0,0,0,10"/>

                    <TextBlock Text="Имя" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox x:Name="FirstNameBox" Margin="0,0,0,10"/>

                    <TextBlock Text="Отчество" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox x:Name="MiddleNameBox" Margin="0,0,0,10"/>

                    <TextBlock Text="Дата рождения" Style="{StaticResource FieldLabelStyle}"/>
                    <DatePicker x:Name="BirthDateBox" Margin="0,0,0,10"/>

                    <TextBlock Text="Пол" Style="{StaticResource FieldLabelStyle}"/>
                    <ComboBox x:Name="GenderBox" Margin="0,0,0,10">
                        <ComboBoxItem Content="Мужской"/>
                        <ComboBoxItem Content="Женский"/>
                    </ComboBox>

                    <TextBlock Text="Телефон" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox x:Name="PhoneBox" Margin="0,0,0,10"/>

                    <TextBlock Text="Адрес" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox x:Name="AddressBox" Margin="0,0,0,10"/>

                    <TextBlock Text="Полис" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox x:Name="PolicyBox" Margin="0,0,0,10"/>

                    <Button x:Name="SaveButton" Content="Добавить пациента" Style="{StaticResource SuccessButtonStyle}" Margin="0,10,0,10" Click="Save_Click"/>
                    <Button Content="Новая запись" Style="{StaticResource InfoButtonStyle}" Margin="0,0,0,10" Click="NewPatient_Click"/>
                    <Button Content="Удалить" Style="{StaticResource DangerButtonStyle}" Margin="0,0,0,10" Click="Delete_Click"/>
                    <Button Content="Обновить список" Style="{StaticResource InfoButtonStyle}" Click="Refresh_Click"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
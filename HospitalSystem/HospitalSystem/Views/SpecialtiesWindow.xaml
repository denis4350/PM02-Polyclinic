<Window x:Class="HospitalSystem.Views.SpecialtiesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Специальности"
        Height="560" Width="760"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource CanvasBrush}">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <Border Style="{StaticResource CardStyle}" Margin="0,0,10,0">
            <DataGrid x:Name="SpecialtiesGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionChanged="SpecialtiesGrid_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding SpecialtyID}" Width="50"/>
                    <DataGridTextColumn Header="Название специальности" Binding="{Binding SpecialtyName}" Width="*"/>
                    <DataGridTextColumn Header="Врачей" Binding="{Binding DoctorsCount}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Column="1" Style="{StaticResource CardStyle}">
            <StackPanel>
                <TextBlock Text="Специальность" FontSize="18" FontWeight="Bold" Margin="0,0,0,14"/>

                <TextBlock Text="Название" Style="{StaticResource FieldLabelStyle}"/>
                <TextBox x:Name="NameBox" Margin="0,0,0,10"/>

                <Button x:Name="SaveButton" Content="Добавить специальность" Style="{StaticResource SuccessButtonStyle}" Margin="0,10,0,10" Click="Save_Click"/>
                <Button Content="Новая запись" Style="{StaticResource InfoButtonStyle}" Margin="0,0,0,10" Click="NewSpecialty_Click"/>
                <Button Content="Удалить" Style="{StaticResource DangerButtonStyle}" Margin="0,0,0,10" Click="Delete_Click"/>
                <Button Content="Обновить список" Style="{StaticResource InfoButtonStyle}" Click="Refresh_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>